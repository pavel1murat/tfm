#------------------------------------------------------------------------------
# data logger FHICL template
#------------------------------------------------------------------------------
    data_logger : {
        process_name: "XX"              ## to be substituted
        
        services: { @table::artdaq_services }
        
        source: { module_type: ArtdaqInput }
        
        outputs: {
            
            rootOutput: { module_type: RootDAQOut
                fileName         : "/tmp/raw.mu2e.trk.vst.%06r_%06s.art"
                compressionLevel : 0
                fileProperties   : {
                    maxSize      : 1500000
                    granularity  :  SubRun
                }
                checkFileName    : false
            }
            
            rootNetOutput: {
                module_type           : "RootNetOutput"
                host_map              : [ ]
                destinations          : { }
                routing_table_config: { @table::routing_table_config }
            }
        }
        
        physics: {
            analyzers: { }
            e1       : [ "rootOutput" ]
            end_paths: [ e1 ]
        }
    }
}

END_PROLOG

#------------------------------------------------------------------------------
# trigger table definitions
#------------------------------------------------------------------------------
#include "common/trigger_tables.fcl"
